    enhanced,
    title=Sketch,
    colback=gray!5,
    colframe=lorelei!80!black,
    coltitle=lorelei!80!black,
    fonttitle=\bfseries,
    attach title to upper,
    after title={:\enskip},
    borderline west={5pt}{0pt}{lorelei},
}

